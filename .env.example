# ============================================
# VIDEO-AI-PT — Environment Template
# ============================================
# Copia este ficheiro para .env e preenche com chaves reais.
# NUNCA commitar o .env com valores preenchidos.
# ============================================

# ----- LLM Providers -----
# Gemini (Google AI Studio) — recomendado para imagem e raciocínio
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenRouter — multi-model routing (Claude, GPT, Gemini, etc)
# https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Anthropic — acesso directo à API da Claude (se não usares Claude Max)
# https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI — para Whisper (legendagem) ou GPT
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ----- Geração de Imagem -----
# Nanobanana (opcional — o squad original do Adavio usa esta)
NANOBANANA_API_KEY=

# ----- Geração de Vídeo IA (camada 1) -----
# A definir após research de stack. Candidatos:
# RUNWAY_API_KEY=
# FAL_API_KEY=          # para Wan 2.2, Flux, etc via fal.ai
# KLING_API_KEY=
# LUMA_API_KEY=
# MINIMAX_API_KEY=

# ----- Edição Programática de Vídeo (camada 3) -----
# A definir após research de stack. Candidatos:
# SHOTSTACK_API_KEY=
# CREATOMATE_API_KEY=

# ----- Legendagem (camada 4) -----
# GLADIA_API_KEY=
# ASSEMBLYAI_API_KEY=

# ----- Scraping / Research Social (opcional) -----
# Apify — scraping de perfis públicos (usado pelo Lens/social-scout)
# https://apify.com/account/integrations
APIFY_TOKEN=

# ----- Search & Research -----
# EXA (web search para agentes)
# https://exa.ai/
EXA_API_KEY=

# ----- Deploy (Fase 2 SaaS) -----
# VERCEL_TOKEN=
# RAILWAY_TOKEN=

# ----- AIOX Core -----
NODE_ENV=development
