# ========================================
# VIDEO-AI-PT — .gitignore
# ========================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Production builds
/dist/
/build/
/.next/
/out/

# Environment variables (NEVER commit)
.env
.env.*
.env.local
.env.*.local
!.env.example

# Runtime data (user outputs, generated per-client)
squad/data/*
!squad/data/.gitkeep
/data/
/outputs/
/packages/

# AIOX runtime
.aiox/
.aiox-runtime/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Editor
.vscode/
.idea/
*.swp
*.swo
.cursor/

# Claude Code (local settings only — shared settings.json can be committed)
.claude/settings.local.json

# Test coverage
coverage/
.nyc_output/

# Temporary
*.tmp
tmp/
temp/
